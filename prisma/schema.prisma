// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id              String    @id @default(cuid())
  name            String
  websiteUrl      String
  dbUrl           String
  status          String    // active | suspended
  apiKey          String?   @unique
  phoneNumber     String?
  nextPaymentDate DateTime
  billingAmount   Float     @default(0)
  billingCurrency String    @default("INR")
  billingCycle    String    @default("MONTHLY") // MONTHLY | QUARTERLY | YEARLY | ONE_TIME
  billingStatus   String    @default("PENDING") // PENDING | PAID | OVERDUE | SUSPENDED
  nextRenewalDate DateTime?
  billingNote     String?
  createdAt       DateTime  @default(now())

  admins          Admin[]
  payments        Payment[]
}

model Admin {
  id        String @id @default(cuid())
  email     String @unique
  password  String
  clientId  String
  client    Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Payment {
  id                       String    @id @default(cuid())
  clientId                 String
  amount                   Float
  currency                 String    @default("INR")
  status                   String    // CREATED | PENDING | PAID | FAILED | CANCELLED
  provider                 String    @default("CASHFREE")
  method                   String?   // legacy field retained for old records
  transactionId            String?   // legacy field retained for old records
  cashfreeOrderId          String?   @unique
  cashfreePaymentId        String?
  cashfreePaymentSessionId String?
  cashfreeReferenceId      String?
  cashfreeWebhookEventId   String?   @unique
  billingCycle             String?
  rawProviderStatus        Json?
  paidAt                   DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @default(now()) @updatedAt
  client                   Client    @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([paidAt])
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  purpose   String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([userId])
  @@index([purpose])
  @@index([usedAt])
  @@index([createdAt])
}
